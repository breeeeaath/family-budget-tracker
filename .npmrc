# BUG_FIX_CONTEXT: Platform-specific native packages (@rollup/rollup-win32-x64-msvc etc.)
# fail on Linux (Vercel) with EBADPLATFORM. The 'force' flag makes npm skip the
# os/cpu check for optional platform deps — the parent packages (rollup, tailwindcss,
# lightningcss) use their own platform detection at runtime.
# This is safe because all three packages are transitive deps, not direct imports.
force=true
