# Doxyfile configuration for TypeScript project
# Family Budget Tracker

# Project info
PROJECT_NAME           = "Family Budget Tracker"
PROJECT_NUMBER         = 1.0.0
PROJECT_BRIEF          = "Family expense tracking PWA with React + Express + SQLite"
OUTPUT_DIRECTORY       = doxygen_output
CREATE_SUBDIRS         = YES

# Input
INPUT                  = src/backend src/frontend server.ts tests
RECURSIVE              = YES
FILE_PATTERNS          = *.ts *.tsx *.js *.jsx
EXCLUDE_PATTERNS       = */node_modules/* */dist/*
EXAMPLE_PATH           = tests

# Parser options — map .ts/.tsx to JavaScript (closest Doxygen-supported language)
EXTENSION_MAPPING      = ts=js tsx=js js=js jsx=js
CASE_SENSE_NAMES       = YES

# Output formats
GENERATE_XML           = YES
GENERATE_HTML          = YES
GENERATE_LATEX         = NO
GENERATE_TREEVIEW      = YES

# Optimization for TypeScript
OPTIMIZE_OUTPUT_FOR_C = NO
TYPEDEF_HIDES_STRUCT   = NO
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = YES
EXTRACT_STATIC         = YES
EXTRACT_LOCAL_CLASSES  = YES
HIDE_UNDOC_RELATIONS   = NO

# Dot/graph options
HAVE_DOT               = NO
UML_LOOK               = YES
UML_LIMIT_NUM_FIELDS   = 10
TEMPLATE_RELATIONS     = YES
CALL_GRAPH             = NO
CALLER_GRAPH           = NO

# Preprocessing
ENABLE_PREPROCESSING   = YES
MACRO_EXPANSION        = YES
EXPAND_ONLY_PREDEF     = NO
SEARCH_INCLUDES        = YES
INCLUDE_PATH           = src

# Source browser
SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
STRIP_CODE_COMMENTS    = NO
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION    = YES

# HTML output
HTML_OUTPUT            = html
HTML_HEADER            =
HTML_FOOTER            =
HTML_STYLESHEET        =
HTML_EXTRA_STYLESHEET  =
HTML_COLORSTYLE_HUE    = 220
HTML_COLORSTYLE_SAT    = 100
HTML_COLORSTYLE_GAMMA  = 80
HTML_DYNAMIC_SECTIONS  = YES

# Quiet mode
QUIET                  = YES
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = NO
WARN_IF_DOC_ERROR      = NO
WARN_NO_PARAMDOC       = NO
WARN_FORMAT            = "$file:$line: $text"

# Search
SEARCHENGINE           = YES
SERVER_BASED_SEARCH    = NO
